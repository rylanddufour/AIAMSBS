# AIAMSBS Environment Variables
# Copy to .env and customize values

# Grafana (default admin password used by Grafana container + MCP SA creator)
GRAFANA_PASSWORD=*** Grafana MCP service account token — AUTO-GENERATED by bootstrap.sh.
# Do not set this manually. bootstrap.sh's create_grafana_mcp_service_account()
# writes it to ~/.hermes/secrets/grafana-mcp.env after the stack is up.
# docker-compose.mcp.yml reads from that file via env_file.

# GitHub (for MCP servers)
GITHUB_PERSONAL_ACCESS_TOKEN=*** PostgreSQL (for MCP servers)
POSTGRES_MCP_DATABASE_URI=
