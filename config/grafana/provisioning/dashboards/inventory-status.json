{
  "annotations": {"list": []},
  "editable": false,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total devices",
      "gridPos": {"x": 0, "y": 0, "w": 8, "h": 4},
      "datasource": {"type": "prometheus", "uid": "aiamsbs-prom"},
      "targets": [
        {
          "expr": "count(up{job=\"blackbox_inventory\"})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null}
            ]
          },
          "mappings": [],
          "unit": "none"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto"
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Up",
      "gridPos": {"x": 8, "y": 0, "w": 8, "h": 4},
      "datasource": {"type": "prometheus", "uid": "aiamsbs-prom"},
      "targets": [
        {
          "expr": "count(probe_success{job=\"blackbox_inventory\"} == 1)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "green", "value": 1}
            ]
          },
          "mappings": [],
          "unit": "none"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto"
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Down",
      "gridPos": {"x": 16, "y": 0, "w": 8, "h": 4},
      "datasource": {"type": "prometheus", "uid": "aiamsbs-prom"},
      "targets": [
        {
          "expr": "count(probe_success{job=\"blackbox_inventory\"} == 0)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "red", "value": 1}
            ]
          },
          "mappings": [],
          "unit": "none"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto"
      }
    },
    {
      "id": 4,
      "type": "bargauge",
      "title": "Inventory Status — Up (green) / Down (red) per device",
      "gridPos": {"x": 0, "y": 4, "w": 24, "h": 18},
      "datasource": {"type": "prometheus", "uid": "aiamsbs-prom"},
      "targets": [
        {
          "expr": "probe_success{job=\"blackbox_inventory\"} * 100",
          "legendFormat": "{{host}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "green", "value": 50},
              {"color": "green", "value": 100}
            ]
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {"text": "DOWN", "color": "red", "index": 0},
                "100": {"text": "UP", "color": "green", "index": 1}
              }
            }
          ],
          "unit": "percent",
          "min": 0,
          "max": 100,
          "noValue": "no data"
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true,
        "valueMode": "color",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "sortOrder": "ascending"
      }
    },
    {
      "id": 5,
      "type": "table",
      "title": "Inventory — Details",
      "gridPos": {"x": 0, "y": 22, "w": 24, "h": 12},
      "datasource": {"type": "prometheus", "uid": "aiamsbs-prom"},
      "targets": [
        {
          "expr": "probe_success{job=\"blackbox_inventory\"}",
          "format": "table",
          "instant": true,
          "refId": "A"
        },
        {
          "expr": "probe_duration_seconds{job=\"blackbox_inventory\"}",
          "format": "table",
          "instant": true,
          "refId": "B"
        }
      ],
      "transformations": [
        {
          "id": "seriesToColumns",
          "options": {"byField": "host"}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "job": true,
              "__name__": true,
              "Value": true,
              "instance": false
            },
            "renameByName": {
              "Time": "",
              "Value #A": "Status",
              "Value #B": "Duration",
              "instance": "IP"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "left",
            "cellOptions": {
              "type": "color-background"
            }
          }
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "Status"},
            "properties": [
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {"color": "red", "value": null},
                    {"color": "green", "value": 1}
                  ]
                }
              },
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "0": {"text": "DOWN"},
                      "1": {"text": "UP"}
                    }
                  }
                ]
              }
            ]
          },
          {
            "matcher": {"id": "byName", "options": "Duration"},
            "properties": [
              {
                "id": "unit",
                "value": "s"
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [{"displayName": "Status", "desc": false}],
        "sortDesc": false,
        "footer": {"show": false}
      }
    }
  ],
  "refresh": "1m",
  "schemaVersion": 38,
  "tags": ["aiamsbs", "inventory", "blackbox"],
  "templating": {"list": []},
  "time": {"from": "now-5m", "to": "now"},
  "timepicker": {},
  "timezone": "",
  "title": "Inventory — Device Status",
  "uid": "inventory-status",
  "version": 1,
  "weekStart": ""
}
