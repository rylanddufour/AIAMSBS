    {
      "id": 50,
      "title": "CPU",
      "type": "gauge",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 0,
        "y": 5
      },
      "targets": [
        {
          "expr": "max by (instance) (100 - (avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\", job=\"integrations/unix\"}[5m])) * 100))",
          "legendFormat": "Host",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green"
              },
              {
                "color": "yellow",
                "value": 80
              },
              {
                "color": "red",
                "value": 90
              }
            ]
          }
        }
      },
      "options": {
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      }
    },
