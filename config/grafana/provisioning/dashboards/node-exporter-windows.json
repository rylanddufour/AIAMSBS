{
  "uid": "aiamsbs-node-exporter-windows",
  "title": "AIAMSBS Windows Exporter (per-host)",
  "tags": [
    "aiamsbs",
    "windows-exporter",
    "per-host"
  ],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 3,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "host",
        "label": "Host",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "aiamsbs-prom"
        },
        "query": "label_values(up{job=\"integrations/windows\"}, host)",
        "refresh": 1,
        "includeAll": false,
        "multi": false,
        "options": [],
        "sort": 1
      }
    ]
  },
  "annotations": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Identity",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 1
      },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 2,
      "title": "Up",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "aiamsbs-prom"
      },
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 3,
        "h": 4
      },
      "targets": [
        {
          "expr": "up{host=\"$host\"}",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 0,
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "title": "Uptime (days)",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "aiamsbs-prom"
      },
      "gridPos": {
        "x": 17,
        "y": 1,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "(time() - windows_system_boot_time_timestamp{host=\"$host\"}) / 86400",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 2,
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 6,
      "title": "Logical CPUs",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "aiamsbs-prom"
      },
      "gridPos": {
        "x": 21,
        "y": 1,
        "w": 3,
        "h": 4
      },
      "targets": [
        {
          "expr": "count(count by (core) (windows_cpu_time_total{host=\"$host\",mode=\"idle\"}))",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 0,
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 10,
      "type": "row",
      "title": "CPU",
      "gridPos": {
        "x": 0,
        "y": 5,
        "w": 24,
        "h": 1
      },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 11,
      "title": "CPU %",
      "type": "gauge",
      "datasource": {
        "type": "prometheus",
        "uid": "aiamsbs-prom"
      },
      "gridPos": {
        "x": 0,
        "y": 6,
        "w": 6,
        "h": 6
      },
      "targets": [
        {
          "expr": "(1 - (sum(rate(windows_cpu_time_total{host=\"$host\",mode=\"idle\"}[$__rate_interval])) / clamp_min(sum(rate(windows_cpu_time_total{host=\"$host\"}[$__rate_interval])), 1))) * 100",
          "refId": "A"
        }
      ],
      "options": {
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 70
              },
              {
                "color": "red",
                "value": 90
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 12,
      "title": "CPU by mode (cores)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "aiamsbs-prom"
      },
      "gridPos": {
        "x": 6,
        "y": 6,
        "w": 18,
        "h": 6
      },
      "targets": [
        {
          "expr": "sum by (mode) (rate(windows_cpu_time_total{host=\"$host\"}[$__rate_interval]))",
          "refId": "A",
          "legendFormat": "{{mode}}"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": false,
            "stacking": {
              "mode": "none"
            }
          }
        },
        "overrides": []
      }
    },
    {
      "id": 20,
      "type": "row",
      "title": "Memory",
      "gridPos": {
        "x": 0,
        "y": 12,
        "w": 24,
        "h": 1
      },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 21,
      "title": "Memory %",
      "type": "gauge",
      "datasource": {
        "type": "prometheus",
        "uid": "aiamsbs-prom"
      },
      "gridPos": {
        "x": 0,
        "y": 13,
        "w": 6,
        "h": 6
      },
      "targets": [
        {
          "expr": "(1 - (windows_memory_available_bytes{host=\"$host\"} / clamp_min(windows_memory_physical_total_bytes{host=\"$host\"}, 1))) * 100",
          "refId": "A"
        }
      ],
      "options": {
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 70
              },
              {
                "color": "red",
                "value": 90
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 22,
      "title": "Memory used vs total (bytes)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "aiamsbs-prom"
      },
      "gridPos": {
        "x": 6,
        "y": 13,
        "w": 18,
        "h": 6
      },
      "targets": [
        {
          "expr": "windows_memory_physical_total_bytes{host=\"$host\"} - windows_memory_available_bytes{host=\"$host\"}",
          "refId": "A",
          "legendFormat": "used"
        },
        {
          "expr": "windows_memory_physical_total_bytes{host=\"$host\"}",
          "refId": "B",
          "legendFormat": "total"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": false,
            "stacking": {
              "mode": "none"
            }
          }
        },
        "overrides": []
      }
    },
    {
      "id": 30,
      "type": "row",
      "title": "Logical disks",
      "gridPos": {
        "x": 0,
        "y": 19,
        "w": 24,
        "h": 1
      },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 31,
      "title": "Disk usage by volume",
      "type": "table",
      "datasource": {
        "type": "prometheus",
        "uid": "aiamsbs-prom"
      },
      "gridPos": {
        "x": 0,
        "y": 20,
        "w": 24,
        "h": 8
      },
      "targets": [
        {
          "expr": "(1 - (windows_logical_disk_free_bytes{host=\"$host\"} / clamp_min(windows_logical_disk_size_bytes{host=\"$host\"}, 1))) * 100",
          "refId": "A",
          "format": "table",
          "instant": true
        }
      ],
      "options": {
        "showHeader": true,
        "sortBy": [
          {
            "displayName": "volume",
            "desc": false
          }
        ]
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "left",
            "cellOptions": {
              "type": "auto"
            }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "instance": true,
              "job": true
            },
            "indexByName": {},
            "renameByName": {
              "Value": "Used %"
            }
          }
        }
      ]
    },
    {
      "id": 40,
      "type": "row",
      "title": "Network",
      "gridPos": {
        "x": 0,
        "y": 28,
        "w": 24,
        "h": 1
      },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 41,
      "title": "Network RX/TX (bytes/s)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "aiamsbs-prom"
      },
      "gridPos": {
        "x": 0,
        "y": 29,
        "w": 24,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum(rate(windows_net_bytes_received_total{host=\"$host\"}[$__rate_interval]))",
          "refId": "A",
          "legendFormat": "RX"
        },
        {
          "expr": "sum(rate(windows_net_bytes_sent_total{host=\"$host\"}[$__rate_interval]))",
          "refId": "B",
          "legendFormat": "TX"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": false,
            "stacking": {
              "mode": "none"
            }
          }
        },
        "overrides": []
      }
    },
    {
      "id": 50,
      "type": "row",
      "title": "Event logs (Windows -> Loki via NxLog)",
      "gridPos": {
        "x": 0,
        "y": 37,
        "w": 24,
        "h": 1
      },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 51,
      "title": "Event log",
      "type": "logs",
      "datasource": {
        "type": "loki",
        "uid": "aiamsbs-loki"
      },
      "gridPos": {
        "x": 0,
        "y": 38,
        "w": 24,
        "h": 12
      },
      "targets": [
        {
          "expr": "{job=\"windows_eventlog\", host=\"$host\"}",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      }
    },
    {
      "id": 4,
      "title": "Product",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "aiamsbs-prom"
      },
      "gridPos": {
        "x": 3,
        "y": 1,
        "w": 8,
        "h": 3
      },
      "targets": [
        {
          "expr": "windows_os_info{host=\"$host\"}",
          "refId": "A",
          "instant": true
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "value",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 0,
          "mappings": [
            {
              "type": "value",
              "options": {
                "1": {
                  "text": "Windows 11 Home",
                  "color": "green"
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 7,
      "title": "Version",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "aiamsbs-prom"
      },
      "gridPos": {
        "x": 3,
        "y": 4,
        "w": 8,
        "h": 3
      },
      "targets": [
        {
          "expr": "windows_os_info{host=\"$host\"}",
          "refId": "A",
          "instant": true
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "value",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 0,
          "mappings": [
            {
              "type": "value",
              "options": {
                "1": {
                  "text": "10.0.26200",
                  "color": "green"
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 8,
      "title": "Revision",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "aiamsbs-prom"
      },
      "gridPos": {
        "x": 11,
        "y": 1,
        "w": 6,
        "h": 3
      },
      "targets": [
        {
          "expr": "windows_os_info{host=\"$host\"}",
          "refId": "A",
          "instant": true
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "value",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 0,
          "mappings": [
            {
              "type": "value",
              "options": {
                "1": {
                  "text": "8655",
                  "color": "green"
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      }
    }
  ],
  "description": "Per-OS host metrics + logs via Grafana Alloy. The AIAMSBS host itself is tracked on aiamsbs-health."
}
