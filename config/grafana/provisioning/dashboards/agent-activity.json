{
  "uid": "agent-activity",
  "title": "AI Agent Activity",
  "tags": [
    "aiamsbs",
    "agent",
    "activity",
    "hermes"
  ],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 2,
  "refresh": "30s",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "templating": {
    "list": []
  },
  "annotations": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "title": "Active Sessions (host)",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "aiamsbs-prom"
      },
      "gridPos": {
        "h": 4,
        "w": 3,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum(hermes_sessions_active)",
          "refId": "A",
          "legendFormat": "Active"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green"
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 10
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "name"
      }
    },
    {
      "id": 2,
      "title": "Kanban In-Flight",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "aiamsbs-prom"
      },
      "gridPos": {
        "h": 4,
        "w": 3,
        "x": 3,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum(hermes_kanban_runs_in_flight)",
          "refId": "A",
          "legendFormat": "Running"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green"
              },
              {
                "color": "yellow",
                "value": 3
              },
              {
                "color": "red",
                "value": 10
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "name"
      }
    },
    {
      "id": 3,
      "title": "Estimated Cost (USD)",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "aiamsbs-prom"
      },
      "gridPos": {
        "h": 4,
        "w": 3,
        "x": 6,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum(hermes_estimated_cost_usd_total)",
          "refId": "A",
          "legendFormat": "Cost"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green"
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 10
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "name"
      }
    },
    {
      "id": 4,
      "title": "Cron Jobs OK (24h)",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "aiamsbs-prom"
      },
      "gridPos": {
        "h": 4,
        "w": 3,
        "x": 9,
        "y": 0
      },
      "targets": [
        {
          "expr": "count(hermes_cron_job_last_success_timestamp > (time() - 86400))",
          "refId": "A",
          "legendFormat": "OK"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red"
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "name"
      }
    },
    {
      "id": 5,
      "title": "agent-exporter",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "aiamsbs-prom"
      },
      "gridPos": {
        "h": 4,
        "w": 2,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "expr": "hermes_exporter_up",
          "refId": "A",
          "legendFormat": "Up"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red"
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "name"
      }
    },
    {
      "id": 10,
      "title": "Active Sessions by Profile",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "aiamsbs-prom"
      },
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 0,
        "y": 4
      },
      "targets": [
        {
          "expr": "sum by (profile) (hermes_sessions_active)",
          "refId": "A",
          "legendFormat": "{{profile}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": true
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      }
    },
    {
      "id": 11,
      "title": "Estimated Cost by Model",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "aiamsbs-prom"
      },
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 8,
        "y": 4
      },
      "targets": [
        {
          "expr": "sum by (model) (hermes_estimated_cost_usd_total)",
          "refId": "A",
          "legendFormat": "{{model}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": true,
            "stacking": {
              "mode": "normal",
              "group": "A"
            }
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      }
    },
    {
      "id": 12,
      "title": "Estimated Cost (Gauge)",
      "type": "gauge",
      "datasource": {
        "type": "prometheus",
        "uid": "aiamsbs-prom"
      },
      "gridPos": {
        "h": 6,
        "w": 4,
        "x": 16,
        "y": 10
      },
      "targets": [
        {
          "expr": "sum(hermes_estimated_cost_usd_total)",
          "refId": "A",
          "legendFormat": "Total"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green"
              },
              {
                "color": "yellow",
                "value": 5
              },
              {
                "color": "red",
                "value": 25
              }
            ]
          }
        }
      },
      "options": {
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      }
    },
    {
      "id": 13,
      "title": "Estimated Cost (Gauge)",
      "type": "gauge",
      "datasource": {
        "type": "prometheus",
        "uid": "aiamsbs-prom"
      },
      "gridPos": {
        "h": 6,
        "w": 4,
        "x": 20,
        "y": 10
      },
      "targets": [
        {
          "expr": "sum(hermes_estimated_cost_usd_total)",
          "refId": "A",
          "legendFormat": "Total"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green"
              },
              {
                "color": "yellow",
                "value": 5
              },
              {
                "color": "red",
                "value": 25
              }
            ]
          }
        }
      },
      "options": {
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      }
    },
    {
      "id": 20,
      "title": "Kanban Runs by Outcome (5m rate)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "aiamsbs-prom"
      },
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 0,
        "y": 16
      },
      "targets": [
        {
          "expr": "sum by (outcome) (rate(hermes_kanban_runs_total[5m]))",
          "refId": "A",
          "legendFormat": "{{outcome}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": true,
            "stacking": {
              "mode": "normal",
              "group": "A"
            }
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      }
    },
    {
      "id": 21,
      "title": "Kanban Runs by Assignee (1h rate)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "aiamsbs-prom"
      },
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 12,
        "y": 16
      },
      "targets": [
        {
          "expr": "sum by (assignee) (rate(hermes_kanban_runs_total[1h]))",
          "refId": "A",
          "legendFormat": "{{assignee}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": true
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      }
    },
    {
      "id": 30,
      "title": "Session Duration p50 / p95 / p99 (last 1h)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "aiamsbs-prom"
      },
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 0,
        "y": 22
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(hermes_session_duration_seconds_bucket[1h])))",
          "refId": "A",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(hermes_session_duration_seconds_bucket[1h])))",
          "refId": "B",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(hermes_session_duration_seconds_bucket[1h])))",
          "refId": "C",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": true
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 31,
      "title": "Session Duration by End Reason",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "aiamsbs-prom"
      },
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 12,
        "y": 22
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, end_reason) (rate(hermes_session_duration_seconds_bucket[1h])))",
          "refId": "A",
          "legendFormat": "p95 {{end_reason}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": true
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      }
    },
    {
      "id": 40,
      "title": "Cron Jobs (last success)",
      "type": "table",
      "datasource": {
        "type": "prometheus",
        "uid": "aiamsbs-prom"
      },
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 0,
        "y": 28
      },
      "targets": [
        {
          "expr": "hermes_cron_job_last_success_timestamp",
          "refId": "A",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "instance": true,
              "job": true
            },
            "indexByName": {
              "Time": 0,
              "Value": 2,
              "job_name": 1
            },
            "renameByName": {
              "Value": "Last Success (unix)",
              "job_name": "Job"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "left"
          }
        }
      },
      "options": {
        "showHeader": true,
        "sortBy": [
          {
            "displayName": "Last Success (unix)",
            "desc": true
          }
        ]
      }
    },
    {
      "id": 50,
      "title": "Live Agent Logs (hermes-agent)",
      "type": "logs",
      "datasource": {
        "type": "loki",
        "uid": "aiamsbs-loki"
      },
      "gridPos": {
        "h": 20,
        "w": 24,
        "x": 0,
        "y": 34
      },
      "targets": [
        {
          "expr": "{job=\"hermes-agent\"}",
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "aiamsbs-loki"
          },
          "queryType": "range"
        }
      ],
      "options": {
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "sortOrder": "Descending",
        "enableLogDetails": true,
        "live": false
      }
    }
  ],
  "revision": 1
}