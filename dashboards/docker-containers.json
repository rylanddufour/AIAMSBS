{
  "dashboard": {
    "title": "Docker Containers",
    "uid": "docker-containers",
    "tags": ["docker", "containers", "aiamsbs"],
    "timezone": "browser",
    "schemaVersion": 38,
    "version": 1,
    "refresh": "30s",
    "templating": {
      "list": [
        {
          "name": "hostname",
          "type": "query",
          "query": "label_names(container_cpu_usage_seconds_total)",
          "refresh": 1,
          "includeAll": true,
          "allValue": ".*",
          "multi": false,
          "hide": 0,
          "label": "Docker Host",
          "description": "Select Docker Host"
        },
        {
          "name": "container",
          "type": "query",
          "query": "label_names(container_cpu_usage_seconds_total{hostname=~\"$hostname\"})",
          "refresh": 1,
          "includeAll": true,
          "allValue": ".*",
          "multi": true,
          "hide": 0,
          "label": "Container",
          "description": "Select Container"
        }
      ]
    },
    "panels": [
      {
        "id": 1,
        "title": "CPU Usage by Container",
        "type": "timeseries",
        "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "rate(container_cpu_usage_seconds_total{hostname=~\"$hostname\", container=~\"$container\"}[$__rate_interval])",
            "legendFormat": "{{container}}"
          }
        ],
        "fieldConfig": {"defaults": {"unit": "percent", "thresholds": {"mode": "absolute", "steps": [{"color": "green"}, {"color": "yellow", "value": 70}, {"color": "red", "value": 85}]}}}
      },
      {
        "id": 2,
        "title": "Memory Usage by Container",
        "type": "timeseries",
        "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8},
        "targets": [
          {"expr": "container_memory_usage_bytes{hostname=~\"$hostname\", container=~\"$container\"}", "legendFormat": "{{container}}"}
        ],
        "fieldConfig": {"defaults": {"unit": "bytes"}}
      },
      {
        "id": 3,
        "title": "Network RX/TX",
        "type": "timeseries",
        "gridPos": {"x": 0, "y": 8, "w": 12, "h": 8},
        "targets": [
          {"expr": "rate(container_network_receive_bytes_total{hostname=~\"$hostname\", container=~\"$container\"}[$__rate_interval])", "legendFormat": "{{container}} RX"},
          {"expr": "rate(container_network_transmit_bytes_total{hostname=~\"$hostname\", container=~\"$container\"}[$__rate_interval])", "legendFormat": "{{container}} TX"}
        ],
        "fieldConfig": {"defaults": {"unit": "Bps"}}
      },
      {
        "id": 4,
        "title": "Block IO",
        "type": "timeseries",
        "gridPos": {"x": 12, "y": 8, "w": 12, "h": 8},
        "targets": [
          {"expr": "rate(container_blkio_read_operation_bytes_total{hostname=~\"$hostname\", container=~\"$container\"}[$__rate_interval])", "legendFormat": "{{container}} Read"},
          {"expr": "rate(container_blkio_write_operation_bytes_total{hostname=~\"$hostname\", container=~\"$container\"}[$__rate_interval])", "legendFormat": "{{container}} Write"}
        ],
        "fieldConfig": {"defaults": {"unit": "Bps"}}
      },
      {
        "id": 5,
        "title": "Container Logs",
        "type": "logs",
        "gridPos": {"x": 0, "y": 16, "w": 24, "h": 12},
        "targets": [
          {"refId": "A", "expr": "{job=\"docker\", hostname=~\"$hostname\", container=~\"$container\"}", "legendFormat": ""}
        ],
        "options": {"showLabels": false, "showCommonLabels": false, "wrapLogMessage": true, "sortOrder": "Descending"}
      }
    ]
  },
  "overwrite": true
}
